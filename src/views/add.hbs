<div class="form-container">
    <h1>Tambah Project Baru</h1>
    
    <form action="/my-project" method="POST">
        <div>
            <label>Nama Project</label>
            <input type="text" name="name" required>
        </div>
        
        <div>
            <label>Deskripsi</label>
            <textarea name="description" rows="4" required></textarea>
        </div>
        
        <div>
            <label>Tag</label>
            <input type="text" name="tag" placeholder="Web, Mobile, dll" required>
        </div>
        
        <div>
            <label>URL Gambar</label>
            <input type="text" name="img" placeholder="https://example.com/gambar.jpg">
        </div>
        
        <button type="submit">Simpan</button>
        <a href="/my-project" class="btn-batal">Batal</a>
    </form>
</div>