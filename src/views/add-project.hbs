<div style="max-width: 600px; margin: 0 auto;">
    <h1>Tambah Project Baru</h1>
    
    <form action="/my-project" method="POST">
        <div>
            <label>Nama Project</label>
            <input type="text" name="name" required>
        </div>
        
        <div>
            <label>Deskripsi</label>
            <textarea name="description" rows="5" required></textarea>
        </div>
        
        <div>
            <label>Upload Gambar</label>
            <input type="file" id="gambar" accept="image/*">
            <input type="hidden" name="image" id="imageBase64">
        </div>
        
        <button type="submit">Simpan Project</button>
    </form>
</div>

<script>
    document.getElementById('gambar').addEventListener('change', async function(e) {
        const file = e.target.files[0];
        if (file) {
            const formData = new FormData();
            formData.append('image', file);
            
            const response = await fetch('/upload-gambar', {
                method: 'POST',
                body: formData
            });
            
            if (response.redirected) {
                window.location.href = response.url;
            }
        }
    });
</script>