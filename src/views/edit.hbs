<div class="form-container">
    <h1>Edit Project</h1>
    
    {{#if session.flash}}
        <div class="alert alert-{{session.flash.type}}">{{session.flash.message}}</div>
    {{/if}}
    
    <form action="/my-project/edit/{{project.id}}" method="POST" enctype="multipart/form-data">
        <div>
            <label>Nama Project</label>
            <input type="text" name="name" value="{{project.name}}" required>
        </div>
        
        <div>
            <label>Deskripsi</label>
            <textarea name="description" rows="4" required>{{project.description}}</textarea>
        </div>
        
        <div>
            <label>Tag</label>
            <input type="text" name="tag" value="{{project.tag}}" required>
        </div>
        
        <div>
            <label>Gambar Saat Ini</label>
            {{#if project.img}}
                <img src="{{project.img}}" width="150">
            {{/if}}
        </div>
        
        <div>
            <label>Ganti Gambar</label>
            <input type="file" name="image" accept="image/*">
            <small>Kosongkan jika tidak ingin mengganti gambar</small>
        </div>
        
        <button type="submit">Update</button>
        <a href="/my-project" class="btn-batal">Batal</a>
    </form>
</div>